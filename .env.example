# INVERSO - Variables de Entorno
# Copiar estas variables en Vercel: Settings > Environment Variables

# ============================================
# PRODUCCIÓN (usar en Vercel)
# ============================================

# URL de la API de INVERSO (Cloudflare Workers)
VITE_API_URL=https://inverso-api.lucasan-videla.workers.dev

# ============================================
# DESARROLLO (usar localmente)
# ============================================

# Descomentar para desarrollo local:
# VITE_API_URL=http://localhost:8787

# ============================================
# NOTAS
# ============================================
# - Todas las variables deben empezar con VITE_ para ser accesibles en el frontend
# - En Vercel, agregar las variables en: Project Settings > Environment Variables
# - No es necesario agregar NODE_ENV, Vercel lo configura automáticamente
